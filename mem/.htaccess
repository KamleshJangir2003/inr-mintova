Options +FollowSymlinks
RewriteEngine On
RewriteBase /inr/mem/

# Remove .php extension
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([^.]+)$ $1.php [L]

# Block direct .php access
RewriteCond %{THE_REQUEST} ^[^\ ]*\ /[^\ ]*\.php
RewriteRule ^(.*)\.php$ /inr/mem/$1 [R=301,L]
